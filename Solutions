# Given a dataframe, rename the columns 'id' to 'student_id', 'first'
import pandas as pd

def renameColumns(students: pd.DataFrame) -> pd.DataFrame:
    return students.rename(
        columns={
            "id":"student_id",
            "first":"first_name",
            "last":"last_name",
            "age":"age_in_years",
        }
    )
